-- B-Bikes workshop scheduler setup for Supabase Cron
--
-- Run this manually in the Supabase SQL editor after deployment.
-- Before running:
-- 1. Enable the `pg_cron`, `pg_net`, and `vault` extensions in Supabase.
-- 2. Replace the placeholder values below with your deployed app URL and CRON_SECRET.
-- 3. If the secret names already exist, update them in the Vault UI instead of re-running create_secret().

select vault.create_secret(
  'https://your-app.example.com',
  'bbikes_app_url',
  'Public base URL for the deployed B-Bikes workshop app'
);

select vault.create_secret(
  'replace-with-your-cron-secret',
  'bbikes_cron_secret',
  'Authorization secret used by Supabase Cron to call /api/cron/sync'
);

-- Kører én gang dagligt kl. 16:00 Copenhagen-tid.
-- Supabase Cron bruger UTC:
--   Sommertid (UTC+2, ca. marts–oktober): brug '0 14 * * *'
--   Vintertid (UTC+1, ca. oktober–marts): brug '0 15 * * *'
select cron.schedule(
  'bbikes-workshop-sync',
  '0 14 * * *',
  $$
  select
    net.http_post(
      url := (select decrypted_secret from vault.decrypted_secrets where name = 'bbikes_app_url') || '/api/cron/sync',
      headers := jsonb_build_object(
        'Content-Type', 'application/json',
        'Authorization', 'Bearer ' || (select decrypted_secret from vault.decrypted_secrets where name = 'bbikes_cron_secret')
      ),
      body := jsonb_build_object(
        'source', 'supabase-cron',
        'scheduled_at', now()
      ),
      timeout_milliseconds := 10000
    ) as request_id;
  $$
);

-- Hvis jobbet allerede eksisterer og du kun vil opdatere tidsplanen:
-- select cron.alter_job(
--   job_id := (select jobid from cron.job where jobname = 'bbikes-workshop-sync'),
--   schedule := '0 14 * * *'
-- );

